{
  "name": "PHP undervisning",
  "image": "mcr.microsoft.com/devcontainers/php:8.3",

  "forwardPorts": [8000],

  "customizations": {
    "vscode": {
      "extensions": [
        "bmewburn.vscode-intelephense-client", 
        "xdebug.php-pack"
      ],
      "settings": {
        "editor.formatOnSave": true
      }
    }
  },

  "postCreateCommand": "php -v && composer --version"
}
